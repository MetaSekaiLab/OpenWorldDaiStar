<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>OpenWorldDaiStar</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="MessagePack" Version="3.1.8" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="OpenWorldDaiStar.Tests" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="../appsettings.json"
             Condition="Exists('../appsettings.json')"
             Link="appsettings.json"
             CopyToOutputDirectory="PreserveNewest"
             CopyToPublishDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
